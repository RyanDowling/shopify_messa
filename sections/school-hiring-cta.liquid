<div class="hiring-cta-section">
  <div class="page-width">
    <div class="cta-content-wrapper">
      
      <h2 class="hiring-title">{{ section.settings.title }}</h2>
      
      <div class="hiring-text">
        {{ section.settings.text }}
      </div>
      
      <a href="{{ section.settings.link }}" class="hiring-btn">
        {{ section.settings.btn_label }}
      </a>

    </div>
  </div>
</div>

<style>
  /* Main Container Styling */
  .hiring-cta-section {
    background-color: {{ section.settings.bg_color }};
    padding: 80px 20px; /* Increased vertical padding for more breathing room */
    margin-top: 60px;
    border-radius: 0; /* Removed radius for a full-width banner feel, or keep 8px if you prefer cards */
  }

  /* Wrapper to center everything perfectly */
  .cta-content-wrapper {
    max-width: 900px;
    margin: 0 auto;
    text-align: center; /* Forces Title and Button to center */
    color: {{ section.settings.text_color }};
  }
  
  /* Big, Bold Title */
  .hiring-title {
    font-size: 36px; /* Much larger */
    font-weight: 700;
    margin-bottom: 25px;
    color: {{ section.settings.text_color }};
    line-height: 1.2;
  }
  
  /* Readable Body Text */
  .hiring-text {
    font-size: 18px; /* Standard web readable size is 16px-18px */
    line-height: 1.6;
    margin-bottom: 40px;
  }

  /* Fix for the Bullet Points alignment */
  .hiring-text ul {
    text-align: left; /* Keeps bullets aligned left */
    display: inline-block; /* Keeps the list block centered relative to the page */
    margin: 20px auto;
    padding-left: 20px;
  }

  .hiring-text li {
    margin-bottom: 10px; /* Spacing between bullet points */
  }
  
  /* The "Big Click" Button */
  .hiring-btn {
    display: inline-block;
    background-color: {{ section.settings.btn_color }};
    color: {{ section.settings.btn_text_color }};
    padding: 18px 40px; /* Large clickable area */
    font-size: 18px;
    font-weight: bold;
    text-decoration: none;
    border-radius: 6px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  .hiring-btn:hover {
    transform: translateY(-2px); /* Slight lift on hover */
    box-shadow: 0 5px 15px rgba(0,0,0,0.2); /* Shadow effect */
    opacity: 0.9;
  }

  /* Mobile Adjustments */
  @media only screen and (max-width: 749px) {
    .hiring-cta-section {
      padding: 50px 20px;
    }
    .hiring-title {
      font-size: 28px;
    }
    .hiring-text {
      font-size: 16px;
    }
    .hiring-btn {
      width: 100%; /* Full width button on mobile */
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "School/Club Hiring CTA",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Partner with Maximum Effort"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text"
    },
    {
      "type": "text",
      "id": "link",
      "label": "Button Link",
      "placeholder": "e.g. mailto:coach@maximumeffort.academy or /pages/contact"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Enquire Now"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1c1c1c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Color",
      "default": "#ffcd00"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "School/Club Hiring CTA"
    }
  ]
}
{% endschema %}