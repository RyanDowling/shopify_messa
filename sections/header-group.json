      "settings": {
        "custom_liquid": "<body>\n\n\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Custom Multiple Link Blocks</title>\n    <style>\n        /* Reset styles */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;\n            background-color: #f5f5f5;\n            padding: 20px;\n        }\n        \n        /* Container for blocks */\n        .link-blocks-container {\n            max-width: 1200px;\n            margin: 0 auto;\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 20px;\n            padding: 20px 0;\n        }\n        \n        /* Individual link block */\n        .link-block {\n            position: relative;\n            height: 250px;\n            overflow: hidden;\n            border-radius: 5px;\n            background-color: #000000; /* Black background as requested */\n            border: 3px solid #ffffff; /* White border as requested */\n            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n        }\n        \n        .link-block:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);\n        }\n        \n        /* Background image for block */\n        .link-block-bg {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            z-index: 1;\n            opacity: 0.9;\n            transition: opacity 0.3s ease;\n        }\n        \n        /* Content container */\n        .link-block-content {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            z-index: 2;\n            padding: 20px;\n            text-align: center;\n            color: #ffffff; /* White text as requested */\n            background-color: rgba(0, 0, 0, 0.8); /* Semi-transparent black background */\n        }\n        \n        .link-block:hover .link-block-bg {\n            opacity: 0.7;\n        }\n        \n        /* Title styling */\n        .link-block-title {\n            font-size: 24px;\n            font-weight: 700;\n            margin-bottom: 10px;\n            color: #ffffff; /* White text as requested */\n        }\n        \n        /* Full block link */\n        .block-link {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: 3;\n            text-decoration: none;\n            color: inherit;\n        }\n        \n        /* New Shop Section Styling */\n        .shop-section {\n            max-width: 1200px;\n            margin: 40px auto;\n            padding: 30px;\n            background-color: #000000;\n            border: 2px solid #ffffff;\n            border-radius: 5px;\n            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\n        }\n        \n        .shop-section-title {\n            font-size: 28px;\n            font-weight: 700;\n            color: #ffffff;\n            text-align: center;\n            margin-bottom: 30px;\n        }\n        \n        /* Responsive adjustments */\n        @media (max-width: 768px) {\n            .link-blocks-container {\n                grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n            }\n            \n            .link-block {\n                height: 200px;\n            }\n            \n            .link-block-title {\n                font-size: 20px;\n            }\n        }\n    </style>\n\n\n    <div class=\"link-blocks-container\">\n        <!-- Block 1 -->\n        <div class=\"link-block\">\n            <img src=\"/api/placeholder/500/500\" alt=\"Training Results\" class=\"link-block-bg\">\n            <div class=\"link-block-content\">\n                <h2 class=\"link-block-title\">Training Results</h2>\n                <p>View your training results and progress</p>\n            </div>\n            <a href=\"https://maximumeffort.academy/pages/training-results\" class=\"block-link\" aria-label=\"Go to Training Results\"></a>\n        </div>\n        \n        <!-- Block 2 -->\n        <div class=\"link-block\">\n            <img src=\"/api/placeholder/500/500\" alt=\"Timetable\" class=\"link-block-bg\">\n            <div class=\"link-block-content\">\n                <h2 class=\"link-block-title\">Timetable</h2>\n                <p>Check our class schedule and availability</p>\n            </div>\n            <a href=\"https://maximumeffort.academy/pages/training-timetable\" class=\"block-link\" aria-label=\"Go to Timetable\"></a>\n        </div>\n        \n        <!-- Block 3 -->\n        <div class=\"link-block\">\n            <img src=\"/api/placeholder/500/500\" alt=\"Coaching Fees\" class=\"link-block-bg\">\n            <div class=\"link-block-content\">\n                <h2 class=\"link-block-title\">Coaching Fees</h2>\n                <p>View our coaching packages and pricing</p>\n            </div>\n            <a href=\"https://maximumeffort.academy/collections/coaching-services\" class=\"block-link\" aria-label=\"Go to Coaching Fees\"></a>\n        </div>\n        \n        <!-- Block 4 - Products -->\n        <div class=\"link-block\">\n            <img src=\"/api/placeholder/500/500\" alt=\"Products\" class=\"link-block-bg\">\n            <div class=\"link-block-content\">\n                <h2 class=\"link-block-title\">Products</h2>\n                <p>Shop our exclusive merchandise</p>\n            </div>\n            <a href=\"https://maximumeffort.academy/collections/products\" class=\"block-link\" aria-label=\"Shop Products\"></a>\n        </div>\n        \n        <!-- Block 5 -->\n        <div class=\"link-block\">\n            <img src=\"/api/placeholder/500/500\" alt=\"Want to Know More\" class=\"link-block-bg\">\n            <div class=\"link-block-content\">\n                <h2 class=\"link-block-title\">Want to Know More</h2>\n                <p>Learn about our training methodology</p>\n            </div>\n            <a href=\"https://maximumeffort.academy/pages/about-us\" class=\"block-link\" aria-label=\"Go to Learn More\"></a>\n        </div>\n        \n        <!-- Block 5 -->\n        <div class=\"link-block\">\n            <img src=\"/api/placeholder/500/500\" alt=\"Apply Here\" class=\"link-block-bg\">\n            <div class=\"link-block-content\">\n                <h2 class=\"link-block-title\">Apply Here</h2>\n                <p>Join our academy today</p>\n            </div>\n            <a href=\"https://maximumeffort.academy/pages/how-to-join\" class=\"block-link\" aria-label=\"Go to Apply\"></a>\n        </div>\n    </div>\n\n</body>",
        "color_scheme": "accent-2",
