ack background */\n        border: 3px solid #ffffff; /* White border */\n        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\n        transition: transform 0.3s ease, box-shadow 0.3s ease;\n    }\n    \n    .link-block:hover {\n        transform: translateY(-5px);\n        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);\n    }\n    \n    /* Background image for block */\n    .link-block-bg {\n        position: absolute;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        object-fit: cover;\n        z-index: 1;\n        opacity: 0.9;\n        transition: opacity 0.3s ease;\n    }\n    \n    /* Content container */\n    .link-block-content {\n        position: absolute;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        display: flex;\n        flex-direction: column;\n        justify-content: center;\n        align-items: center;\n        z-index: 2;\n        padding: 20px;\n        text-align: center;\n        color: #ffffff; /* White text */\n        background-color: rgba(0, 0, 0, 0.8); /* Semi-transparent black background */\n    }\n    \n    .link-block:hover .link-block-bg {\n        opacity: 0.7;\n    }\n    \n    /* Title styling */\n    .link-block-title {\n        font-size: 24px;\n        font-weight: 700;\n        margin-bottom: 10px;\n        color: #ffffff; /* White text */\n    }\n    \n    /* Full block link */\n    .block-link {\n        position: absolute;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        z-index: 3;\n        text-decoration: none;\n        color: inherit;\n    }\n    \n    /* Responsive adjustments */\n    @media (max-width: 768px) {\n        .link-blocks-container {\n            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n            padding: 0 10px; /* Smaller padding on mobile */\n        }\n        \n        .link-block {\n            height: 200px;\n        }\n        \n        .link-block-title {\n    