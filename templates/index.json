        "custom_liquid": "<div class=\"me-tiles-section\">\n  <div class=\"link-blocks-container\">\n      <div class=\"link-block\">\n          <div class=\"link-block-content\">\n              <h2 class=\"link-block-title\">About Our Academy</h2>\n              <p>Meet the coaches and our training philosophy</p>\n          </div>\n          <a href=\"https://maximumeffort.academy/pages/about-us\" class=\"block-link\" aria-label=\"Go to About Us\"></a>\n      </div>\n\n      <div class=\"link-block link-block--cta\">\n          <div class=\"link-block-content\">\n              <h2 class=\"link-block-title\">Apply Here</h2>\n              <p>Register for a free come and try session</p>\n          </div>\n          <a href=\"https://maximumeffort.academy/pages/how-to-join\" class=\"block-link\" aria-label=\"Go to Apply\"></a>\n      </div>\n\n      <div class=\"link-block\">\n          <div class=\"link-block-content\">\n              <h2 class=\"link-block-title\">Coaching Fees</h2>\n              <p>View our coaching packages and pricing</p>\n          </div>\n          <a href=\"https://maximumeffort.academy/collections/coaching-services\" class=\"block-link\" aria-label=\"Go to Coaching Fees\"></a>\n      </div>\n\n      <div class=\"link-block\">\n          <div class=\"link-block-content\">\n              <h2 class=\"link-block-title\">Timetable</h2>\n              <p>Check our class schedule and availability</p>\n          </div>\n          <a href=\"https://maximumeffort.academy/pages/training-timetable\" class=\"block-link\" aria-label=\"Go to Timetable\"></a>\n      </div>\n\n      <div class=\"link-block\">\n          <div class=\"link-block-content\">\n              <h2 class=\"link-block-title\">Training Results</h2>\n              <p>View athlete progress and performance data</p>\n          </div>\n          <a href=\"https://maximumeffort.academy/pages/training-results\" class=\"block-link\" aria-label=\"Go to Training Results\"></a>\n      </div>\n\n      <div class=\"link-block\">\n          <div class=\"link-block-content\">\n              <h2 class=\"link-block-title\">Products</h2>\n              <p>Shop our exclusive merchandise</p>\n          </div>\n          <a href=\"https://maximumeffort.academy/collections/products\" class=\"block-link\" aria-label=\"Shop Products\"></a>\n      </div>\n  </div>\n</div>\n\n<style>\n    .me-tiles-section {\n        width: 100%;\n        background-color: #ffffff;\n        padding: 40px 20px;\n        box-sizing: border-box;\n    }\n\n    .link-blocks-container * {\n        margin: 0;\n        padding: 0;\n        box-sizing: border-box;\n    }\n\n    .link-blocks-container {\n        max-width: 1200px;\n        margin: 0 auto;\n        display: grid;\n        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n        gap: 20px;\n        background-color: #ffffff;\n    }\n\n    .link-block {\n        position: relative;\n        height: 250px;\n        overflow: hidden;\n        border-radius: 5px;\n        background-color: #111111;\n        border: 3px solid #ffffff;\n        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\n        transition: transform 0.3s ease, box-shadow 0.3s ease;\n    }\n\n    .link-block:hover {\n        transform: translateY(-5px);\n        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);\n    }\n\n    .link-block--cta {\n        border-color: #82f2b3;\n        box-shadow: 0 4px 12px rgba(130, 242, 179, 0.3);\n    }\n\n    .link-block-content {\n        position: absolute;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        display: flex;\n        flex-direction: column;\n        justify-content: center;\n        align-items: center;\n        padding: 20px;\n        text-align: center;\n        color: #ffffff;\n    }\n\n    .link-block-title {\n        font-size: 24px;\n        font-weight: 700;\n        margin-bottom: 10px;\n        color: #ffffff;\n    }\n\n    .block-link {\n        position: absolute;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        z-index: 3;\n        text-decoration: none;\n        color: inherit;\n    }\n\n    @media (max-width: 768px) {\n        .link-blocks-container {\n            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n            padding: 0 10px;\n        }\n\n        .link-block {\n            height: 200px;\n        }\n\n        .link-block-title {\n            font-size: 20px;\n        }\n    }\n</style>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function() {\n    const linkBlocks = document.querySelectorAll('.link-block');\n    linkBlocks.forEach(block => {\n      block.addEventListener('click', function() {\n        const link = this.querySelector('.block-link');\n        if (link && link.href) {\n          window.location.href = link.href;\n        }\n      });\n    });\n  });\n</script>",
